              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a new data collection in your workspace."
        },
        {
          "info": {
            "name": "Get a collection",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.customer.io/v1/api/collections/:collection_id",
            "params": [
              {
                "name": "collection_id",
                "value": "",
                "type": "path",
                "description": "The unique identifier for the collection."
              }
            ]
          },
          "docs": "Returns detailed information about a specific collection."
        },
        {
          "info": {
            "name": "Update a collection",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.customer.io/v1/api/collections/:collection_id",
            "params": [
              {
                "name": "collection_id",
                "value": "",
                "type": "path",
                "description": "The unique identifier for the collection."
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Updates the contents or configuration of a data collection."
        },
        {
          "info": {
            "name": "Delete a collection",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.customer.io/v1/api/collections/:collection_id",
            "params": [
              {
                "name": "collection_id",
                "value": "",
                "type": "path",
                "description": "The unique identifier for the collection."
              }
            ]
          },
          "docs": "Deletes a data collection from your workspace."
        }
      ]
    },
    {
