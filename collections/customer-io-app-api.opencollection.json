              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates or updates a reusable content snippet."
        },
        {
          "info": {
            "name": "Delete a snippet",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.customer.io/v1/snippets/:snippet_name",
            "params": [
              {
                "name": "snippet_name",
                "value": "",
